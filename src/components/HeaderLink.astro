---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const normalizePath = (value: string) => decodeURIComponent(value).replace(/\/+$/, '') || '/';
const normalizedHref = normalizePath(String(href));
const normalizedPathname = normalizePath(pathname);
const subpath = normalizedPathname.match(/[^\/]+/g);
const isActive =
	normalizedHref === normalizedPathname || normalizedHref === '/' + (subpath?.[0] || '');
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-flex;
		align-items: center;
		text-decoration: none;
	}
	a.active {
		font-weight: 600;
	}
</style>
