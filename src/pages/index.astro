---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCategoryPath, getPublishedPosts, getPostsByCategory } from '../lib/blog';

const posts = await getPublishedPosts();
const stockPosts = getPostsByCategory(posts, '주식').slice(0, 3);
const realEstatePosts = getPostsByCategory(posts, '부동산').slice(0, 3);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 720px;
			}
			.hero {
				margin-bottom: 4em;
			}
			.hero h1 {
				margin-bottom: 0.3em;
				font-size: 2.5em;
				line-height: 1.2;
				letter-spacing: -0.02em;
			}
			.hero-desc {
				color: rgb(var(--gray));
				font-size: 1.1em;
				line-height: 1.6;
				margin-bottom: 2em;
			}
			.category-section {
				margin-bottom: 4em;
			}
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 1.5em;
				border-bottom: 2px solid rgba(var(--border), 0.5);
				padding-bottom: 0.5em;
			}
			.section-title {
				font-size: 1.5em;
				font-weight: 700;
				margin: 0;
				color: rgb(var(--black));
			}
			.view-more {
				color: var(--accent);
				text-decoration: none;
				font-size: 0.95em;
				font-weight: 600;
			}
			.view-more:hover {
				text-decoration: underline;
			}
			.posts-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-item {
				margin-bottom: 2.5em;
			}
			.post-item a {
				text-decoration: none;
				color: inherit;
			}
			.post-item h3 {
				margin: 0 0 0.3em 0;
				color: rgb(var(--black));
				font-size: 1.35em;
			}
			.post-item h3:hover {
				color: var(--accent);
			}
			.post-date {
				color: rgb(var(--gray));
				font-size: 0.9em;
				margin-bottom: 0.5em;
			}
			.post-description {
				color: rgb(var(--gray));
				font-size: 1em;
				line-height: 1.5;
				margin: 0;
			}
			.empty-state {
				padding: 2em 0;
				text-align: center;
				color: rgb(var(--gray));
				font-style: italic;
				background: rgba(var(--surface), 0.5);
				border-radius: 8px;
			}
			@media (max-width: 720px) {
				main {
					max-width: 100%;
				}
				.hero {
					margin-bottom: 3em;
				}
				.hero h1 {
					font-size: 2em;
				}
				.category-section {
					margin-bottom: 3em;
				}
				.post-item {
					margin-bottom: 1.6em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>투자의 나침반,<br/>주식과 부동산 인사이트</h1>
				<p class="hero-desc">한국 시장의 핵심 트렌드를 깊이 있게 분석합니다.</p>
			</section>

			<section class="category-section">
				<div class="section-header">
					<h2 class="section-title">📈 주식</h2>
					<a href={getCategoryPath('주식')} class="view-more">더보기 &rarr;</a>
				</div>
				{stockPosts.length > 0 ? (
					<ul class="posts-list">
						{stockPosts.map((post) => (
							<li class="post-item">
								<a href={`/blog/${post.id}/`}>
									<h3 class="post-title title-clamp">{post.data.title}</h3>
								</a>
								<div class="post-date">
									{post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
								</div>
								<p class="post-description">{post.data.description}</p>
							</li>
						))}
					</ul>
				) : (
					<div class="empty-state">
						<p>아직 등록된 글이 없습니다.</p>
					</div>
				)}
			</section>

			<section class="category-section">
				<div class="section-header">
					<h2 class="section-title">🏢 부동산</h2>
					<a href={getCategoryPath('부동산')} class="view-more">더보기 &rarr;</a>
				</div>
				{realEstatePosts.length > 0 ? (
					<ul class="posts-list">
						{realEstatePosts.map((post) => (
							<li class="post-item">
								<a href={`/blog/${post.id}/`}>
									<h3 class="post-title title-clamp">{post.data.title}</h3>
								</a>
								<div class="post-date">
									{post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
								</div>
								<p class="post-description">{post.data.description}</p>
							</li>
						))}
					</ul>
				) : (
					<div class="empty-state">
						<p>아직 등록된 글이 없습니다.</p>
					</div>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>